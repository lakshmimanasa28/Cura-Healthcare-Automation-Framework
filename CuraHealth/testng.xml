<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Automation Suite" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="listener.TestListener"/>
    </listeners>

    <test name="User Authentication Tests">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <test name="Appointment Booking Tests">
        <classes>
            <class name="tests.AppointmentBookingTest"/>
        </classes>
    </test>

    <test name="Appointment History Tests">
        <classes>
            <class name="tests.AppointmentHistoryTest"/>
        </classes>
    </test>

    <test name="Multiple Appointments Tests">
        <classes>
            <class name="tests.MultipleAppointmentsTest"/>
        </classes>
    </test>

    <test name="Form Validations Tests">
        <classes>
            <class name="tests.FormValidationsTest"/>
        </classes>
    </test>

</suite>